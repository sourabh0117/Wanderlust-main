<style>
  .search-btn{
    background-color: #fe424d;
    color: #fff;
    padding: 0 1rem 0 1rem;
    border-radius: 25px;
  }
  .search-btn:hover{
    background-color: #fe424d;
    color: #fff;
  }

  .search-btn i{
    display: inline;
    margin-right: 0.5rem;
  }

  .search-inp{
    border-radius: 25px;
    padding:  0.5rem 2rem 0.5rem 3rem;
    font-size: 1rem;
  }

  .search-bar {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 40%;
    z-index: 1060;
  }

  .navbar .container-fluid {
    position: relative;
  }

  .navbar-collapse {
    position: absolute;
    transition: all 0.3s ease;
    top: 100%;
    left: 0;
    width: 100%;
    z-index: 1050;
  }

  .navbar-toggler-body {
    background: #fe424d;
    border-radius: 20px;
    overflow: hidden;
    text-align: center;
  }

  .navbar-toggler-body .nav-link {
    color: white !important;
    padding: 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.3);
    font-weight: 500;
  }

  .navbar-toggler-body .nav-link:last-child {
    border-bottom: none;
  }

  .navbar-toggler-body .nav-link:hover {
    background: rgba(255,255,255,0.1);
  }

  .filtersSection {
    position: sticky;
    top: 5rem;
    z-index: 999;
  }

  @media (min-width: 768px) {
    .navbar-collapse {
      position: static;
      width: auto;
    }

    .navbar-toggler-body {
      background: none;
      border-radius: 0;
    }

    .navbar-toggler-body .nav-link {
      color: black !important;
      border: none;
      padding: 0.5rem;
    }
  }


</style>


<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <div class="container-fluid">

    <!-- LEFT: Logo + Explore -->
    <div class="d-flex align-items-center">
      <a class="navbar-brand me-3" href="/listings">
        <i class="fa-regular fa-compass"></i>
      </a>

      <a class="nav-link" href="/listings">Explore</a>
    </div>

    <!-- CENTER: Search -->
    <form class="d-flex mx-auto search-bar" action="/listings/search" method="get">
      <input class="form-control me-2 search-inp" type="text" name="s" placeholder="Search destination" />
      <button class="btn search-btn" type="submit">
        <i class="fa-solid fa-magnifying-glass"></i>
      </button>
    </form>

    <!-- RIGHT: Hamburger -->
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- RIGHT: Collapse Content -->
    <div class="collapse navbar-collapse justify-content-end" id="navbarNavAltMarkup">
      <div class="navbar-nav navbar-toggler-body">

        <a class="nav-link" href="/listings/new"><b>Be a local boss</b></a>

        <% if(!currUser) { %>
          <a class="nav-link" href="/signup"><b>Signup</b></a>
          <a class="nav-link" href="/login"><b>Login</b></a>
        <% } %>

        <% if(currUser) { %>
          <a class="nav-link" href="/logout">Logout</a>
        <% } %>

      </div>
    </div>

  </div>
</nav>